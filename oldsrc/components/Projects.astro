---
interface Props {
    small?: boolean
}

const {small = false} = Astro.props;
---

<div class:list={["projects", small?"small":null]}>
    <slot />
</div>

<style>
    .projects {
        align-self: center;
        justify-self: center;
        gap: 1em;
    }

    @media (width <= 700px) {
        .projects {
            display: flex;
            flex-direction: column;
        }
    }
    @media (width > 700px) {
        .projects {
            width: max(40em, 60vw);
            max-width: 70em;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));

            &.small {
                width: 100%;
                max-width: 100%;
                grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            }
        }
    }
</style>
